<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

	<changeSet id="27" author="nmalservet">
		<comment>a user who already has data attached (e.g. survey responses) is archived instead of deleted</comment>
		<addColumn tableName="user_internal">
			<column name="archived" type="boolean" defaultValueBoolean="false">
				<constraints nullable="false"/>
			</column>
		</addColumn>
	</changeSet>

</databaseChangeLog>
