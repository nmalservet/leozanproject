<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
	xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
		http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

	<changeSet id="24" author="nmalservet">
		<preConditions onFail="MARK_RAN">
			<sqlCheck expectedResult="0">SELECT COUNT(*) FROM role WHERE id = 1</sqlCheck>
		</preConditions>
		<comment>role definitions</comment>
		<insert tableName="role">
			<column name="id" valueNumeric="1"/>
			<column name="name" value="administrator"/>
			<column name="description" value="admin user can do all actions on the system"/>
		</insert>
		<insert tableName="role">
			<column name="id" valueNumeric="2"/>
			<column name="name" value="manager"/>
			<column name="description" value="manager user can do all actions "/>
		</insert>
		<insert tableName="role">
			<column name="id" valueNumeric="3"/>
			<column name="name" value="guest"/>
			<column name="description" value="guest user"/>
		</insert>
	</changeSet>

	<changeSet id="25" author="nmalservet">
		<preConditions onFail="MARK_RAN">
			<sqlCheck expectedResult="0">SELECT COUNT(*) FROM select_list WHERE id = 1</sqlCheck>
		</preConditions>
		<comment>status select list for surveys</comment>
		<insert tableName="select_list">
			<column name="id" valueNumeric="1"/>
			<column name="name" value="surveyStatus"/>
			<column name="description" value="statuses for a survey"/>
			<column name="label" value="status"/>
		</insert>
		<insert tableName="select_list_option">
			<column name="id" valueNumeric="1"/>
			<column name="name" value="new"/>
			<column name="label" value="New"/>
			<column name="display_order" valueNumeric="0"/>
			<column name="key" valueNumeric="0"/>
			<column name="select_list_id" valueNumeric="1"/>
		</insert>
		<insert tableName="select_list_option">
			<column name="id" valueNumeric="2"/>
			<column name="name" value="validated"/>
			<column name="label" value="In progress"/>
			<column name="display_order" valueNumeric="1"/>
			<column name="key" valueNumeric="1"/>
			<column name="select_list_id" valueNumeric="1"/>
		</insert>
		<insert tableName="select_list_option">
			<column name="id" valueNumeric="3"/>
			<column name="name" value="deployed"/>
			<column name="label" value="Done"/>
			<column name="display_order" valueNumeric="2"/>
			<column name="key" valueNumeric="2"/>
			<column name="select_list_id" valueNumeric="1"/>
		</insert>
		<insert tableName="select_list_option">
			<column name="id" valueNumeric="4"/>
			<column name="name" value="disabled"/>
			<column name="label" value="Disabled"/>
			<column name="display_order" valueNumeric="3"/>
			<column name="key" valueNumeric="3"/>
			<column name="select_list_id" valueNumeric="1"/>
		</insert>
	</changeSet>

</databaseChangeLog>
